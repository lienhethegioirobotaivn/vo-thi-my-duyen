datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model HeroConfig {
  id             String       @id @default(cuid())
  bgUrl          String?      
  topSubtitle    String?      
  mainTitleLine1 String?      
  mainTitleLine2 String?      
  engSubtitle    String?      
  descVi         String?      
  descEn         String?      
  buttons        HeroButton[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model HeroButton {
  id           String     @id @default(cuid())
  textVi       String?   
  textEn       String?   
  primary      Boolean?   @default(false)
  href         String?   
  order        Int?       @default(0)    
  heroConfigId String
  heroConfig   HeroConfig @relation(fields: [heroConfigId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([heroConfigId])
}

model Stat {
  id        String   @id @default(cuid())
  value     String?
  titleVi   String?
  titleEn   String?
  iconSrc   String?
  order     Int?     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProfileConfig {
  id        String        @id @default(cuid())
  titleVi   String?       @default("HỒ SƠ NỔI BẬT")
  titleEn   String?       @default("PROFILE HIGHLIGHTS")
  avatarUrl String?
  items     ProfileItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ProfileItem {
  id              String        @id @default(cuid())
  vi              String?
  en              String?
  order           Int?          @default(0)
  profileConfigId String
  profileConfig   ProfileConfig @relation(fields: [profileConfigId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([profileConfigId])
}

model ExpertiseConfig {
  id        String      @id @default(cuid())
  titleVi   String?     @default("CÁC MẢNG CHUYÊN MÔN")
  titleEn   String?     @default("AREAS OF EXPERTISE")
  items     Expertise[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Expertise {
  id                String          @id @default(cuid())
  vi                String?
  en                String?
  icon              String?
  order             Int?            @default(0)
  expertiseConfigId String
  expertiseConfig   ExpertiseConfig @relation(fields: [expertiseConfigId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([expertiseConfigId])
}

model ServicesConfig {
  id        String        @id @default(cuid())
  titleVi   String?       @default("DỊCH VỤ CUNG CẤP")
  titleEn   String?       @default("SERVICES")
  items     ServiceItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ServiceItem {
  id               String         @id @default(cuid())
  vi               String?
  en               String?
  img              String?
  order            Int?           @default(0)
  servicesConfigId String
  servicesConfig   ServicesConfig @relation(fields: [servicesConfigId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([servicesConfigId])
}

model MediaConfig {
  id          String           @id @default(cuid())
  titleVi     String?          @default("KẾT NỐI & HỢP TÁC QUỐC TẾ")
  titleEn     String?          @default("INTERNATIONAL CONNECTIONS & COLLABORATIONS")
  descVi      String?
  descEn      String?
  mapImg      String?
  countries   MediaCountry[]
  highlights  MediaHighlight[]
  tvStations  MediaTvStation[]
  pressItems  MediaPressItem[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model MediaCountry {
  id            String      @id @default(cuid())
  vi            String?
  en            String?
  flag          String?
  order         Int?        @default(0)
  mediaConfigId String
  mediaConfig   MediaConfig @relation(fields: [mediaConfigId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([mediaConfigId])
}

model MediaHighlight {
  id            String      @id @default(cuid())
  titleVi       String?
  titleEn       String?
  img           String?
  href          String?     @default("#")
  order         Int?        @default(0)
  mediaConfigId String
  mediaConfig   MediaConfig @relation(fields: [mediaConfigId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([mediaConfigId])
}

model MediaTvStation {
  id            String      @id @default(cuid())
  src           String?
  order         Int?        @default(0)
  mediaConfigId String
  mediaConfig   MediaConfig @relation(fields: [mediaConfigId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([mediaConfigId])
}

model MediaPressItem {
  id            String      @id @default(cuid())
  logo          String?
  article       String?
  order         Int?        @default(0)
  mediaConfigId String
  mediaConfig   MediaConfig @relation(fields: [mediaConfigId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([mediaConfigId])
}

model ConnectTrainingConfig {
  id               String            @id @default(cuid())
  trainingTitleVi  String?           @default("CHƯƠNG TRÌNH ĐÀO TẠO")
  trainingTitleEn  String?           @default("TRAINING PROGRAMS")
  connectTitleVi   String?           @default("KẾT NỐI VỚI TÔI")
  connectTitleEn   String?           @default("CONNECT WITH ME")
  fanpageTitle     String?           @default("FANPAGE")
  fanpageUrl       String?           @default("https://www.facebook.com/KingsmanEducationOrganization")
  logoIcon         String?           @default("/navbar/logo.png")
  programs         TrainingProgram[]
  socials          SocialLink[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model TrainingProgram {
  id                      String                @id @default(cuid())
  vi                      String?
  en                      String?
  icon                    String?
  order                   Int?                  @default(0)
  connectTrainingConfigId String
  connectTrainingConfig   ConnectTrainingConfig @relation(fields: [connectTrainingConfigId], references: [id], onDelete: Cascade)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  @@index([connectTrainingConfigId])
}

model SocialLink {
  id                      String                @id @default(cuid())
  titleVi                 String?
  titleEn                 String?
  linkText                String?
  url                     String?
  bgColor                 String?               @default("#1877F2")
  iconImg                 String?
  order                   Int?                  @default(0)
  connectTrainingConfigId String
  connectTrainingConfig   ConnectTrainingConfig @relation(fields: [connectTrainingConfigId], references: [id], onDelete: Cascade)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  @@index([connectTrainingConfigId])
}

model ActivityConfig {
  id        String          @id @default(cuid())
  titleVi   String?         @default("HÌNH ẢNH HOẠT ĐỘNG")
  titleEn   String?         @default("ACTIVITY HIGHLIGHTS")
  items     ActivityImage[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model ActivityImage {
  id               String         @id @default(cuid())
  src              String?
  order            Int?           @default(0)
  activityConfigId String
  activityConfig   ActivityConfig @relation(fields: [activityConfigId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([activityConfigId])
}

model ClientConfig {
  id          String        @id @default(cuid())
  titleVi     String?       @default("KHÁCH HÀNG CHIẾN LƯỢC")
  titleEn     String?       @default("STRATEGIC CLIENTS")
  footerVi    String?       @default("VÀ HƠN 2,000+ DOANH NGHIỆP & TỔ CHỨC TRÊN TOÀN QUỐC")
  footerEn    String?       @default("AND 2,000+ ENTERPRISES & ORGANIZATIONS NATIONWIDE")
  tabs        ClientTab[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ClientTab {
  id             String       @id @default(cuid())
  tabKey         String
  vi             String?
  en             String?
  order          Int?         @default(0)
  clientConfigId String
  clientConfig   ClientConfig @relation(fields: [clientConfigId], references: [id], onDelete: Cascade)
  logos          ClientLogo[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([clientConfigId])
}

model ClientLogo {
  id          String    @id @default(cuid())
  src         String?
  order       Int?      @default(0)
  clientTabId String
  clientTab   ClientTab @relation(fields: [clientTabId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clientTabId])
}

model NavbarConfig {
  id           String       @id @default(cuid())
  logo         String?      @default("/navbar/logo.png")
  nameVi       String?      @default("ThS. VÕ THỊ MỸ DUYÊN")
  nameEn       String?      @default("ThS. VO THI MY DUYEN")
  subtitle1Vi  String?      @default("GIẢNG VIÊN - DIỄN GIẢ - CỐ VẤN CHIẾN LƯỢC")
  subtitle1En  String?      @default("Lecturer - Speaker - Strategic Advisor")
  bookTextVi   String?      @default("ĐẶT LỊCH NGAY")
  bookTextEn   String?      @default("BOOK NOW")
  bookHref     String?      @default("#book")
  navItems     NavItem[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model NavItem {
  id             String       @id @default(cuid())
  labelVi        String?
  labelEn        String?
  href           String?
  order          Int?         @default(0)
  navbarConfigId String
  navbarConfig   NavbarConfig @relation(fields: [navbarConfigId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([navbarConfigId])
}

model FooterConfig {
  id              String   @id @default(cuid())
  contactTitleVi  String?  @default("THÔNG TIN LIÊN HỆ")
  contactTitleEn  String?  @default("CONTACT INFORMATION")
  phone           String?  @default("090 000 0000")
  email           String?  @default("duyen@kingsman.edu.vn")
  website         String?  @default("www.vothimyduyen.com")
  addressVi       String?  @default("TP. Hồ Chí Minh, Việt Nam")
  addressEn       String?  @default("Ho Chi Minh City, Vietnam")
  bookTitleVi     String?  @default("ĐẶT LỊCH DIỄN GIẢ")
  bookTitleEn     String?  @default("BOOK THE SPEAKER")
  newsletterTitleVi String? @default("NHẬN TÀI LIỆU & CẬP NHẬT")
  newsletterTitleEn String? @default("GET RESOURCES & UPDATES")
  newsletterDescVi  String? @default("Đăng ký nhận tài liệu, thông tin mới nhất và lịch đào tạo từ ThS. Võ Thị Mỹ Duyên.")
  newsletterDescEn  String? @default("Subscribe to receive latest resources, updates & training schedule.")
  copyrightText   String?  @default("© 2026 ThS. Võ Thị Mỹ Duyên. All rights reserved.")
  sloganText      String?  @default("Inspire Minds – Empower Change – Create Lasting Value")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Metadata {
  id          String   @id @default(uuid())
  title       String   @default("ThS. Võ Thị Mỹ Duyên | Giảng viên, Diễn giả & Cố vấn chiến lược")
  description String   @default("Khám phá hành trình và dịch vụ của ThS. Võ Thị Mỹ Duyên - Giảng viên chuyên nghiệp, Diễn giả truyền cảm hứng và Cố vấn chiến lược uy tín cho doanh nghiệp.")
  keywords    String   @default("Võ Thị Mỹ Duyên, ThS Võ Thị Mỹ Duyên, Diễn giả Võ Thị Mỹ Duyên, Cố vấn chiến lược, Giảng viên")
  ogTitle     String   @default("ThS. Võ Thị Mỹ Duyên | Giảng viên, Diễn giả & Cố vấn chiến lược")
  ogDesc      String   @default("Chuyên gia đào tạo, diễn giả truyền cảm hứng và cố vấn chiến lược phát triển.")
  ogImage     String   @default("/anh_se_them_vao_tu_admin_page.jpg")
  favicon     String   @default("/favicon.ico")
  siteUrl     String   @default("https://www.vothimyduyen.com")
  updatedAt   DateTime @updatedAt
}